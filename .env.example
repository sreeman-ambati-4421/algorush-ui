# Neon Postgres connection string (same DB the bot writes to via Algo/utils/db.py)
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/momentum?sslmode=require

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated list of emails allowed to sign in
ALLOWED_EMAILS=you@example.com

# Internal trade service (Algo/api/trade_service.py), running on the bot host
TRADE_API_URL=https://your-bot-host:8787
TRADE_API_SECRET=shared-secret-matching-the-bot-hosts-TRADE_API_SECRET
